                    </div>
                </div>

                <!-- Contact 4 -->
                <div class="contact-card">
                    <div class="contact-header">
                        <span class="contact-name">Taylor Reed</span>
                        <div class="group-tags">
                            <span class="group-tag"><i class="fas fa-school"></i> regis jesuit</span>
                            <span class="group-tag"><i class="fas fa-graduation-cap"></i> alumni</span>
