<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Networking Tracker · Groups & Calendar</title>
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background: #e5e5e5;
            display: flex;
            justify-content: center;
            padding: 30px 20px;
            min-height: 100vh;
        }

        .container {
            max-width: 1400px;
            width: 100%;
            background: white;
            border-radius: 28px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            overflow: hidden;
            border: 1px solid #c0c0c0;
        }

        /* Header - Black/Grey */
        .header {
            background: #1a1a1a;
            color: white;
            padding: 20px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 4px solid #808080;
        }

        .header h1 {
            font-weight: 350;
            font-size: 28px;
            letter-spacing: -0.3px;
        }

        .header h1 i {
            color: #b0b0b0;
            margin-right: 15px;
        }

        .github-badge {
            background: #333;
            color: #ddd;
            padding: 8px 22px;
            border-radius: 40px;
            font-size: 14px;
            border: 1px solid #777;
        }

        .github-badge i {
            margin-right: 8px;
            color: #ccc;
        }

        /* Groups Filter Bar */
        .groups-bar {
            background: #f0f0f0;
            padding: 15px 25px;
            display: flex;
            flex-wrap: wrap;
            gap: 10px 12px;
            border-bottom: 1px solid #bfbfbf;
        }

        .group-chip {
            background: white;
            border: 1px solid #aaa;
            color: #2a2a2a;
            padding: 8px 20px;
            border-radius: 40px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.15s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.03);
        }

        .group-chip:hover {
            background: #e0e0e0;
            border-color: #777;
        }

        .group-chip.active {
            background: #2a2a2a;
            color: white;
            border-color: #2a2a2a;
        }

        /* Main Grid - 2 Columns */
        .main-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            background: #fafafa;
        }

        /* Left Column - Contacts */
        .contacts-panel {
            background: white;
            border-right: 1px solid #d0d0d0;
            padding: 25px;
        }

        .contact-card {
            background: #f7f7f7;
            border: 1px solid #d4d4d4;
            border-radius: 24px;
            padding: 22px;
            margin-bottom: 22px;
            transition: 0.2s;
            box-shadow: 0 5px 12px -8px rgba(0,0,0,0.2);
        }

        .contact-card:hover {
            border-color: #999;
            background: #fcfcfc;
        }

        .contact-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .contact-name {
            font-size: 24px;
            font-weight: 500;
            color: #1e1e1e;
        }

        .group-tags {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .group-tag {
            background: #dadada;
            border: 1px solid #a9a9a9;
            color: #222;
            padding: 4px 14px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .group-tag i {
            margin-right: 5px;
            font-size: 11px;
            color: #4a4a4a;
        }

        /* Follow-up Steps Row */
        .steps-row {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin: 18px 0;
            border-top: 1px solid #c9c9c9;
            padding-top: 18px;
        }

        .step {
            background: #e9e9e9;
            border: 1px solid #b9b9b9;
            padding: 8px 18px;
            border-radius: 40px;
            font-size: 14px;
            font-weight: 450;
            color: #2b2b2b;
            cursor: pointer;
            transition: 0.1s;
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .step i {
            color: #5a5a5a;
            font-size: 13px;
        }

        .step.completed {
            background: #2b2b2b;
            border-color: #2b2b2b;
            color: white;
        }

        .step.completed i {
            color: #ccc;
        }

        /* Calendar Row in Contact Card */
        .call-row {
            background: #ececec;
            border: 1px solid #bfbfbf;
            border-radius: 50px;
            padding: 10px 16px;
            display: flex;
            align-items: center;
            gap: 20px;
            margin-top: 10px;
            font-size: 14px;
        }

        .gcal-link {
            background: transparent;
            border: 1px dashed #7a7a7a;
            padding: 5px 16px;
            border-radius: 30px;
            font-size: 13px;
            cursor: pointer;
            transition: 0.1s;
            margin-left: auto;
        }

        .gcal-link:hover {
            background: #dbdbdb;
        }

        .gcal-link i {
            margin-right: 6px;
            color: #4f4f4f;
        }

        /* Right Column - Calendar */
        .calendar-panel {
            background: #f3f3f3;
            padding: 25px;
        }

        .calendar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 22px;
        }

        .calendar-header h2 {
            font-weight: 400;
            font-size: 24px;
            color: #202020;
        }

        .calendar-header h2 i {
            margin-right: 12px;
            color: #606060;
        }

        .google-tag {
            background: #333;
            color: white;
            padding: 8px 20px;
            border-radius: 40px;
            font-size: 14px;
        }

        .month-box {
            background: white;
            border-radius: 24px;
            padding: 20px;
            border: 1px solid #c5c5c5;
            margin-bottom: 25px;
        }

        .month-title {
            text-align: center;
            font-weight: 500;
            margin-bottom: 18px;
            color: #2c2c2c;
        }

        .weekdays {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            text-align: center;
            font-weight: 600;
            color: #4a4a4a;
            margin-bottom: 10px;
            font-size: 14px;
        }

        .days-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 6px;
        }

        .day {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f2f2f2;
            border-radius: 50%;
            border: 1px solid #cdcdcd;
            font-size: 14px;
            color: #2e2e2e;
            cursor: pointer;
        }

        .day.today {
            background: #2b2b2b;
            color: white;
            border-color: #2b2b2b;
        }

        .day.has-call {
            border: 2px solid #6f6f6f;
            font-weight: 600;
        }

        .upcoming-box {
            background: white;
            border-radius: 20px;
            padding: 20px;
            border: 1px solid #c5c5c5;
        }

        .upcoming-box h3 {
            font-weight: 400;
            margin-bottom: 18px;
            color: #262626;
            border-bottom: 1px solid #c9c9c9;
            padding-bottom: 10px;
        }

        .upcoming-item {
            background: #f3f3f3;
            border: 1px solid #c0c0c0;
            border-radius: 14px;
            padding: 12px 15px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .upcoming-item i {
            color: #555;
        }

        .footer-note {
            margin-top: 20px;
            font-size: 12px;
            color: #6f6f6f;
            text-align: center;
            border-top: 1px dashed #b0b0b0;
            padding-top: 15px;
        }
    </style>
</head>
<body>
